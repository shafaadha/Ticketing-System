datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model tenants {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now())
  tickets   tickets[]
  users     users[]
  messages  messages[]
}

model tickets {
  id                                   Int              @id @default(autoincrement())
  tenantId                             Int
  title                                String
  description                          String
  status                               tickets_status   @default(open)
  priority                             tickets_priority @default(medium)
  assignedAgentId                      Int?
  customerId                           Int
  createdAt                            DateTime         @default(now())
  updatedAt                            DateTime         @default(now())
  users_tickets_assignedAgentIdTousers users?           @relation("tickets_assignedAgentIdTousers", fields: [assignedAgentId], references: [id], map: "Tickets_assignedAgentId_fkey")
  users_tickets_customerIdTousers      users            @relation("tickets_customerIdTousers", fields: [customerId], references: [id], map: "Tickets_customerId_fkey")
  tenants                              tenants          @relation(fields: [tenantId], references: [id], map: "Tickets_tenantId_fkey")
  messages                             messages[]

  @@index([assignedAgentId], map: "Tickets_assignedAgentId_fkey")
  @@index([customerId], map: "Tickets_customerId_fkey")
  @@index([tenantId], map: "Tickets_tenantId_fkey")
}

model users {
  id                                     Int        @id @default(autoincrement())
  tenantId                               Int
  name                                   String
  email                                  String     @unique(map: "Users_email_key")
  password                               String
  createdAt                              DateTime   @default(now())
  role                                   users_role @default(customer)
  tickets_tickets_assignedAgentIdTousers tickets[]  @relation("tickets_assignedAgentIdTousers")
  tickets_tickets_customerIdTousers      tickets[]  @relation("tickets_customerIdTousers")
  tenants                                tenants    @relation(fields: [tenantId], references: [id], map: "Users_tenantId_fkey")
  messages                               messages[]

  @@index([tenantId], map: "Users_tenantId_fkey")
}

model messages {
  id       Int @id @default(autoincrement())
  ticketId Int
  senderId Int
  tenantId Int

  content   String   @db.Text
  createdAt DateTime @default(now())

  ticket tickets @relation(fields: [ticketId], references: [id])
  sender users   @relation(fields: [senderId], references: [id])
  tenant tenants @relation(fields: [tenantId], references: [id])

  @@index([ticketId])
  @@index([ticketId, createdAt])
  @@index([senderId])
  @@index([tenantId])
}

enum tickets_status {
  open
  in_progress
  resolved
  closed
}

enum tickets_priority {
  low
  medium
  high
}

enum users_role {
  admin
  agent
  customer
}
